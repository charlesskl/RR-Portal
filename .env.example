# ─── Server ───
NGINX_PORT=80
DEBUG=false

# ─── Database ───
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=enterprise
DB_PORT=5432

# ─── Redis ───
REDIS_PORT=6379

# ─── JWT ───
JWT_SECRET=                     # REQUIRED: at least 32 random chars (openssl rand -base64 48)
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── Admin Bootstrap ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                 # REQUIRED: set strong password (min 10 chars)
ADMIN_EMAIL=admin@company.com
