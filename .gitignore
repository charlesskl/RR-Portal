# DevOps backups (keep directory, ignore content)
devops/backups/*.bak

# DevOps config lock files
devops/config/*.lock

# Apps - ignore nested git repos and build artifacts
apps/*/.git/
apps/*/node_modules/
apps/*/.next/
apps/*/dist/
apps/*/build/
