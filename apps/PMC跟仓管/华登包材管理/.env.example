# 复制为 .env 并填入真实值 (放在服务器的 apps/huadeng/.env,不提交到仓库)

# SQLite 数据目录,容器内路径
DATA_PATH=/app/data

# 监听端口 (docker 容器内固定 5000,本地开发可覆盖)
# PORT=5000

# Flask session cookie 签名密钥 (长随机串,部署时必设)
HUADENG_SECRET_KEY=change-me-to-a-long-random-string

# 3 个板块的登录账号和密码 (独立,互不相通)
# 不设置时使用代码里的默认值(仅供测试,生产务必覆盖)
#   SEC1 = 华登和邵阳华登包材往来    默认 hd / hd123456
#   SEC2 = 兴信和华登包材往来        默认 xx / xx123456
#   SEC3 = 邵阳华登和兴信包材往来    默认 sy / sy123456
HUADENG_SEC1_USER=hd
HUADENG_SEC1_PASSWORD=hd123456
HUADENG_SEC2_USER=xx
HUADENG_SEC2_PASSWORD=xx123456
HUADENG_SEC3_USER=sy
HUADENG_SEC3_PASSWORD=sy123456
