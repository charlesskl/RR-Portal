# 复制为 .env 并填入真实值 (放在服务器的 apps/peise/.env,不提交到仓库)
#
# OCR 后端: 阿里云百炼 (Bailian) OpenAI 兼容端点 + 通义千问 VL Max

# 必填: 阿里云百炼 API key
# (https://bailian.console.aliyun.com/?tab=model#/api-key)
BAILIAN_API_KEY=

# 必填: 百炼 OpenAI 兼容端点
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 必填: 通义千问多模态模型
BAILIAN_MODEL=qwen-vl-max-latest

# 登录(单密码模式)
# AUTH_USERNAME / AUTH_PASSWORD 必填,否则启动报错
AUTH_USERNAME=
AUTH_PASSWORD=
# 可选: 不设会自动在 instance/.secret_key 生成并持久化
# 要手动设也行: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
