# 生产计划管理系统 — 服务端环境变量模板
# 复制为 .env 后填入实际值。生产环境由 docker-compose 通过 environment/env_file 注入。

# 端口（容器内）
PORT=8080

# 静态资源目录（Docker 环境由 Dockerfile 固定为 /app/client/dist）
# CLIENT_DIST=/app/client/dist

# 扫描 Z 盘功能（本地 Windows 专用；Linux 容器请留空或挂载网盘路径）
# SCAN_DIR=Z:/各客排期

# 金山文档 API（可选，如需「写入金山文档」功能）
# KINGSOFT_APP_ID=
# KINGSOFT_ACCESS_TOKEN=
# KINGSOFT_FILE_ID=
