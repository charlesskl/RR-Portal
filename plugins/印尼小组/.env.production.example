# ============================================
# 生产环境变量模板
# 复制为 .env.production 并填入实际值
# cp .env.production.example .env.production
# ============================================

# --- Docker Image 配置 ---
# Docker Registry 地址（默认 Docker Hub）
REGISTRY=docker.io
# 镜像名称
IMAGE_NAME=charlesskl/shipment-checker
# 镜像标签（部署脚本会自动用 git hash 覆盖）
IMAGE_TAG=latest

# --- 应用配置 ---
# 对外暴露端口（Nginx 监听端口映射）
APP_PORT=80

# --- 时区 ---
TZ=Asia/Shanghai

# --- 部署配置（deploy.sh 使用）---
# 远端服务器 IP 或域名（必填）
DEPLOY_SERVER=
# SSH 用户名（默认 root）
DEPLOY_USER=root
# SSH 端口（默认 22）
DEPLOY_SSH_PORT=22
# 远端部署目录
DEPLOY_DIR=/opt/shipment-checker
