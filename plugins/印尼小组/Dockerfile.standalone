FROM nginx:1.25-alpine

# 复制自定义 Nginx 配置
COPY plugins/印尼小组/nginx-standalone.conf /etc/nginx/nginx.conf

# 复制静态 HTML 文件
COPY plugins/印尼小组/印尼出货明细资料核对系统.html /usr/share/nginx/html/index.html

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -qO /dev/null http://localhost:8080/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
