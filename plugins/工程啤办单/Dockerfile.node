FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache tini wget

COPY package.json package-lock.json ./
RUN npm ci --production

COPY server.js ./
COPY public/ ./public/
COPY data/ ./data/

EXPOSE 3000

HEALTHCHECK --interval=10s --timeout=5s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3000/health || exit 1

ENTRYPOINT ["tini", "--"]
CMD ["node", "server.js"]
